# ============ Rust / Anchor ============
target/
.anchor/
test-ledger/

# Solana 1.18 side-install ledger dirs — created when the validator runs with
# `--ledger sv-118` from various subdirs. Multi-GB rocksdb state, never commit.
**/sv-118/

# Solana program upgrade authority keypairs — NEVER commit these.
# Anyone with these can replace the deployed program with arbitrary code.
**/*-keypair.json

# ============ Node / Next.js ============
node_modules/
.next/
out/
.yarn/cache
.pnp.*

# ============ Indexer runtime data ============
services/indexer/data/*.jsonl

# ============ Publisher runtime state ============
# Tracks per-constituent last_fresh_day for stale-decay fallback.  Per-environment,
# regenerated on every run — not source.
services/publisher/examples/*.state.json

# ============ Publisher signing keypairs ============
# Injected at runtime via the PUBLISHER_KEYPAIR_JSON env var (Railway secret);
# never committed. The local files here are only the local-dev fallback that
# load_publisher_keypair() reads when that env var is unset.
services/publisher/devnet-keys/

# ============ Brand assets — raw card downloads ============
# The X banner uses a few PMT25 card images embedded as base64.  We keep the
# raw PNGs out of the repo to honor the README's "no bundled card art" policy
# for the runtime dashboard.  Re-download via docs/brand/build-banner.ps1.
docs/brand/card-src/

# ============ Claude Code local state ============
.claude/

# ============ Env / secrets ============
.env
.env.local
.env.*.local

# ============ Logs ============
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============ OS ============
.DS_Store
Thumbs.db

# ============ IDE ============
.vscode/
.idea/
*.swp
*.swo
