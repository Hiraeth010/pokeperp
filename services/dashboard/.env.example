# Copy to .env.local and adjust.
#
# RPC URL of the cluster the dashboard reads from.
# - Local validator (default for dev):  http://127.0.0.1:8899
# - Devnet:                              https://api.devnet.solana.com
# - Mainnet:                             https://api.mainnet-beta.solana.com
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899

# Program IDs. These are the canonical IDs after `anchor keys sync`.
# If you regenerate program keypairs (anchor build with fresh target/), update these.
NEXT_PUBLIC_ORACLE_PROGRAM_ID=GXEGbfvQvUh77udPyDYeVxgMZYd4BWLtu164dcLhqJ4i
NEXT_PUBLIC_PERP_PROGRAM_ID=Gtpv6K9Fi3pkYcYZEzqaS8DW2nqDwpwPf24Q1WxsQzsa
